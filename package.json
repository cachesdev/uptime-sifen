{
  "name": "uptime-sifen",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "pnpm run db:migrate:prod && node build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "pnpm exec dotenvx run -f .env.development -- vitest",
    "test": "pnpm run test:unit -- --run && npm run test:e2e",
    "docker:up": "pnpm exec dotenvx run -f .env.development -- docker compose -f compose.yaml up -d",
    "docker:down": "pnpm exec dotenvx run -f .env.development -- docker compose -f compose.yaml down",
    "db:pull": "NODE_OPTIONS='--import tsx' pnpm exec dotenvx run -f .env.development -- tsx scripts/preprocess-drizzle.ts",
    "db:migrate": "pnpm exec dotenvx run -f .env.development -- node-pg-migrate up -j ts --tsx true --tsconfig tsconfig.json",
    "db:migrate:create": "node-pg-migrate create -j ts --tsx true",
    "db:migrate:prod": "pnpm exec node-pg-migrate up -j ts --tsx true --tsconfig tsconfig.json",
    "test:e2e": "playwright install && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "next",
    "@sveltejs/kit": "next",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "^24",
    "@types/node-cron": "^3.0.11",
    "@vitest/browser-playwright": "^4.1.8",
    "drizzle-kit": "1.0.0-rc.3",
    "drizzle-orm": "1.0.0-rc.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsrepo": "^3.8.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.73.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "luxon": "^3.7.2",
    "node-cron": "^4.5.0",
    "node-pg-migrate": "^8.0.4",
    "phosphor-svelte": "^3.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "valibot": "^1.4.1"
  }
}
